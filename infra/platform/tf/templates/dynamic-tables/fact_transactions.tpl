SELECT
    TRANSACTION_ID,
    CUSTOMER_ID,
    PRIMARY_BRANCH_ID               AS BRANCH_ID,
    TRANSACTION_REFERENCE           AS REFERENCE_NUMBER,
    TRANSACTION_TYPE,
    TRANSACTION_DATE,
    TRANSACTION_TIMESTAMP,
    TRANSACTION_AMOUNT              AS AMOUNT,
    TRANSACTION_CURRENCY            AS CURRENCY,
    TRANSACTION_STATUS              AS STATUS,
    TRANSACTION_CHANNEL             AS CHANNEL,
    TRANSACTION_DESCRIPTION         AS DESCRIPTION,
    MERCHANT_NAME,
    MERCHANT_CATEGORY,
    MERCHANT_CITY,
    TRANSACTION_COUNTRY_CODE        AS COUNTRY_CODE,
    IS_INTERNATIONAL,
    FRAUD_IS_FLAGGED,
    FRAUD_FLAG_REASON,
    FRAUD_REVIEWED,
    AUTHORIZATION_CODE,
    PROCESSOR,
    SETTLEMENT_DATE
FROM ${database}.${source_schema}.${table}
WHERE TRANSACTION_ID IS NOT NULL
