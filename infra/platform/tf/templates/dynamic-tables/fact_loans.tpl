SELECT
    LOAN_ID,
    CUSTOMER_ID,
    PRIMARY_BRANCH_ID               AS BRANCH_ID,
    LOAN_TYPE,
    LOAN_PURPOSE,
    LOAN_STATUS,
    LOAN_AMOUNT,
    LOAN_OUTSTANDING_BALANCE        AS OUTSTANDING_BALANCE,
    LOAN_INTEREST_RATE              AS INTEREST_RATE,
    LOAN_TERM_MONTHS                AS TERM_MONTHS,
    LOAN_EMI_AMOUNT                 AS EMI_AMOUNT,
    LOAN_DISBURSEMENT_DATE          AS DISBURSEMENT_DATE,
    LOAN_MATURITY_DATE              AS MATURITY_DATE,
    LOAN_PAYMENTS_MADE              AS PAYMENTS_MADE,
    LOAN_MISSED_PAYMENTS            AS MISSED_PAYMENTS,
    LOAN_NEXT_PAYMENT_DATE          AS NEXT_PAYMENT_DATE,
    LOAN_NEXT_PAYMENT_AMOUNT        AS NEXT_PAYMENT_AMOUNT,
    LOAN_ORIGINATION_FEE            AS ORIGINATION_FEE,
    LOAN_PREPAYMENT_PENALTY         AS PREPAYMENT_PENALTY,
    LOAN_OFFICER_ID,
    LOAN_COLLATERAL                 AS COLLATERAL,
    LOAN_INSURANCE                  AS INSURANCE,
    LOAN_CO_BORROWER                AS CO_BORROWER
FROM ${database}.${source_schema}.${table}
WHERE LOAN_ID IS NOT NULL
