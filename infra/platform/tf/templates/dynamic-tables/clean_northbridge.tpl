WITH ranked AS (
    SELECT
        INDEX_RECORD_TS,
        JSON_DATA,
        RECORD_COUNT,
        JSON_VERSION,
        _STG_FILE_NAME,
        _STG_FILE_LOAD_TS,
        _STG_FILE_MD5,
        _COPY_DATA_TS,
        ROW_NUMBER() OVER (
            PARTITION BY INDEX_RECORD_TS
            ORDER BY _STG_FILE_LOAD_TS DESC
        ) AS LATEST_FILE_RANK
    FROM ${database}.${source_schema}.${table}
    WHERE INDEX_RECORD_TS IS NOT NULL
)
SELECT
    r.INDEX_RECORD_TS,
    r.JSON_VERSION,
    r._STG_FILE_NAME,
    r._STG_FILE_LOAD_TS,
    r._COPY_DATA_TS,
    r.JSON_DATA:bank::STRING                                        AS BANK_NAME,
    c.value:customer_id::STRING                                     AS CUSTOMER_ID,
    c.value:first_name::STRING                                      AS FIRST_NAME,
    c.value:last_name::STRING                                       AS LAST_NAME,
    c.value:full_name::STRING                                       AS FULL_NAME,
    c.value:email::STRING                                           AS EMAIL,
    c.value:phone_primary::STRING                                   AS PHONE_PRIMARY,
    c.value:phone_secondary::STRING                                 AS PHONE_SECONDARY,
    c.value:date_of_birth::DATE                                     AS DATE_OF_BIRTH,
    c.value:age::INT                                                AS AGE,
    c.value:gender::STRING                                          AS GENDER,
    c.value:marital_status::STRING                                  AS MARITAL_STATUS,
    c.value:nationality::STRING                                     AS NATIONALITY,
    c.value:number_of_dependents::INT                               AS NUMBER_OF_DEPENDENTS,
    c.value:annual_income::FLOAT                                    AS ANNUAL_INCOME,
    c.value:credit_score::INT                                       AS CREDIT_SCORE,
    c.value:credit_score_date::DATE                                 AS CREDIT_SCORE_DATE,
    c.value:customer_segment::STRING                                AS CUSTOMER_SEGMENT,
    c.value:customer_tier::STRING                                   AS CUSTOMER_TIER,
    c.value:risk_rating::STRING                                     AS RISK_RATING,
    c.value:onboarding_channel::STRING                              AS ONBOARDING_CHANNEL,
    c.value:onboarding_date::DATE                                   AS ONBOARDING_DATE,
    c.value:primary_branch::STRING                                  AS PRIMARY_BRANCH,
    c.value:relationship_manager::STRING                            AS RELATIONSHIP_MANAGER,
    c.value:mailing_address_same::BOOLEAN                           AS MAILING_ADDRESS_SAME,
    c.value:address:street::STRING                                  AS ADDRESS_STREET,
    c.value:address:city::STRING                                    AS ADDRESS_CITY,
    c.value:address:state::STRING                                   AS ADDRESS_STATE,
    c.value:address:zip_code::STRING                                AS ADDRESS_ZIP_CODE,
    c.value:address:country::STRING                                 AS ADDRESS_COUNTRY,
    c.value:address:address_type::STRING                            AS ADDRESS_TYPE,
    c.value:address:since_date::DATE                                AS ADDRESS_SINCE_DATE,
    c.value:address:verified::BOOLEAN                               AS ADDRESS_VERIFIED,
    c.value:employment:employer::STRING                             AS EMPLOYER,
    c.value:employment:status::STRING                               AS EMPLOYMENT_STATUS,
    c.value:income_verification:method::STRING                      AS INCOME_VERIFICATION_METHOD,
    c.value:income_verification:verified::BOOLEAN                   AS INCOME_VERIFIED,
    c.value:income_verification:verified_date::DATE                 AS INCOME_VERIFIED_DATE,
    c.value:compliance:kyc_status::STRING                           AS KYC_STATUS,
    c.value:compliance:kyc_completed_date::DATE                     AS KYC_COMPLETED_DATE,
    c.value:compliance:kyc_expiry_date::DATE                        AS KYC_EXPIRY_DATE,
    c.value:compliance:aml_risk_score::FLOAT                        AS AML_RISK_SCORE,
    c.value:compliance:aml_last_reviewed::DATE                      AS AML_LAST_REVIEWED,
    c.value:compliance:pep_status::STRING                           AS PEP_STATUS,
    c.value:compliance:fatca_status::STRING                         AS FATCA_STATUS,
    c.value:compliance:crs_reportable::BOOLEAN                      AS CRS_REPORTABLE,
    c.value:compliance:sanctions_checked::BOOLEAN                   AS SANCTIONS_CHECKED,
    c.value:compliance:sanctions_last_checked::DATE                 AS SANCTIONS_LAST_CHECKED,
    c.value:compliance:tax_residency::STRING                        AS TAX_RESIDENCY,
    c.value:compliance:tin::STRING                                  AS TIN,
    c.value:digital_profile:has_online_banking::BOOLEAN             AS HAS_ONLINE_BANKING,
    c.value:digital_profile:has_mobile_app::BOOLEAN                 AS HAS_MOBILE_APP,
    c.value:digital_profile:mobile_app_version::STRING              AS MOBILE_APP_VERSION,
    c.value:digital_profile:last_login_date::TIMESTAMP_NTZ          AS LAST_LOGIN_DATE,
    c.value:digital_profile:last_login_channel::STRING              AS LAST_LOGIN_CHANNEL,
    c.value:digital_profile:mfa_enabled::BOOLEAN                    AS MFA_ENABLED,
    c.value:digital_profile:mfa_method::STRING                      AS MFA_METHOD,
    c.value:digital_profile:preferred_language::STRING              AS PREFERRED_LANGUAGE,
    c.value:digital_profile:paperless_enrolled::BOOLEAN             AS PAPERLESS_ENROLLED,
    c.value:digital_profile:consent:data_sharing::BOOLEAN           AS CONSENT_DATA_SHARING,
