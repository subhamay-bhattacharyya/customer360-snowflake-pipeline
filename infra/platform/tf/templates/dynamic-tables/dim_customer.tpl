    TOTAL_ACCOUNTS,
    TOTAL_DEPOSIT_BALANCE,
    TOTAL_LOAN_OUTSTANDING,
    TOTAL_CREDIT_CARDS,
    TOTAL_CREDIT_CARD_BALANCE,
    TOTAL_LOANS,
    ESTIMATED_NET_WORTH,
    LIFETIME_VALUE_SCORE,
    CHURN_RISK_SCORE,
    RELATIONSHIP_DEPTH,
    NEXT_BEST_PRODUCT
