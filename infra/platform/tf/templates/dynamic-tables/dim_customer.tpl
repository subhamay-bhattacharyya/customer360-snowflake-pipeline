    ADDRESS_ZIP_CODE,
    ADDRESS_COUNTRY,
    ADDRESS_TYPE,
    ADDRESS_SINCE_DATE,
    ADDRESS_VERIFIED,
    EMPLOYER,
    EMPLOYMENT_STATUS,
