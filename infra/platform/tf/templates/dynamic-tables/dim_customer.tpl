        TOTAL_CREDIT_CARDS,
        TOTAL_CREDIT_CARD_BALANCE,
        TOTAL_LOANS,
        ESTIMATED_NET_WORTH,
        LIFETIME_VALUE_SCORE,
        CHURN_RISK_SCORE,
        RELATIONSHIP_DEPTH,
        NEXT_BEST_PRODUCT,
        ROW_NUMBER() OVER (PARTITION BY CUSTOMER_ID ORDER BY INDEX_RECORD_TS DESC) AS RN
    FROM ${database}.${source_schema}.${table}
    WHERE CUSTOMER_ID IS NOT NULL
)
SELECT
    CUSTOMER_ID,
    FIRST_NAME,
    LAST_NAME,
    FULL_NAME,
    EMAIL,
    PHONE_PRIMARY,
    PHONE_SECONDARY,
    DATE_OF_BIRTH,
