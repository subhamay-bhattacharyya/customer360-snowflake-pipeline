{
  "storage_integrations": {
    "s3": {
      "name": "S3_STORAGE_INTEGRATION",
      "storage_provider": "S3",
      "storage_allowed_locations": [
        "raw-data/json/"
      ],
      "enabled": true,
      "comment": "[cust360] S3 storage integration for NorthBridge raw data bucket"
    }
  },
  "api_integrations": {
    "github": {
      "name": "GITHUB_API_INT",
      "api_provider": "git_https_api",
      "api_allowed_prefixes": [
        "https://github.com/subhamay-bhattacharyya/customer360-snowflake-pipeline"
      ],
      "enabled": true,
      "comment": "[cust360] API integration for the customer360-snowflake-pipeline GitHub repo used to deploy Streamlit in Snowflake apps"
    }
  },
  "warehouses": {
    "load_wh": {
      "name": "LOAD_WH",
      "comment": "[cust360] Snowpipe ingestion and COPY operations",
      "warehouse_size": "MEDIUM",
      "auto_resume": true,
      "auto_suspend": 60,
      "enable_query_acceleration": false,
      "warehouse_type": "STANDARD",
      "min_cluster_count": 1,
      "max_cluster_count": 1,
      "scaling_policy": "STANDARD",
      "initially_suspended": true
    },
    "transform_wh": {
      "name": "TRANSFORM_WH",
      "comment": "[cust360] Dynamic Table refresh, BRONZE to SILVER to GOLD transforms",
      "warehouse_size": "X-SMALL",
      "auto_resume": true,
      "auto_suspend": 60,
      "enable_query_acceleration": false,
      "warehouse_type": "STANDARD",
      "min_cluster_count": 1,
      "max_cluster_count": 1,
      "scaling_policy": "STANDARD",
      "initially_suspended": true
    },
    "streamlit_wh": {
      "name": "STREAMLIT_WH",
      "comment": "[cust360] Dashboard queries",
      "warehouse_size": "X-SMALL",
      "auto_resume": true,
      "auto_suspend": 60,
      "enable_query_acceleration": false,
      "warehouse_type": "STANDARD",
      "min_cluster_count": 1,
      "max_cluster_count": 1,
      "scaling_policy": "STANDARD",
      "initially_suspended": true
    },
    "adhoc_wh": {
      "name": "ADHOC_WH",
      "comment": "[cust360] Development and ad-hoc debugging",
      "warehouse_size": "X-SMALL",
      "auto_resume": true,
      "auto_suspend": 60,
      "enable_query_acceleration": false,
      "warehouse_type": "STANDARD",
      "min_cluster_count": 1,
      "max_cluster_count": 1,
      "scaling_policy": "STANDARD",
      "initially_suspended": true
    }
  },
  "databases": {
    "northbridge_database": {
      "name": "NORTHBRIDGE_DATABASE",
      "comment": "[cust360] Central analytical database for the NorthBridge Customer 360 pipeline",
      "schemas": [
        {
          "name": "BRONZE",
          "comment": "[cust360] Raw ingestion layer",
          "tables": {
            "raw_northbridge": {
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "BRONZE",
              "name": "RAW_NORTHBRIDGE",
              "table_type": "TRANSIENT",
              "drop_before_create": true,
              "data_retention_time_in_days": 1,
              "comment": "[cust360] Raw ingestion table — VARIANT payload + audit columns",
              "columns": [
                {
                  "name": "ID",
                  "type": "NUMBER(38,0)",
                  "nullable": false,
                  "comment": "[cust360] Surrogate PK",
                  "autoincrement": {
                    "start": 1,
                    "increment": 1,
                    "order": false
                  }
                },
                {
                  "name": "INDEX_RECORD_TS",
                  "type": "TIMESTAMP_NTZ",
                  "nullable": false,
                  "comment": "[cust360] Record timestamp from source"
                },
                {
                  "name": "JSON_DATA",
                  "type": "VARIANT",
                  "nullable": false,
                  "comment": "[cust360] Raw JSON payload"
                },
                {
                  "name": "RECORD_COUNT",
                  "type": "NUMBER(38,0)",
                  "nullable": false
                },
                {
                  "name": "JSON_VERSION",
                  "type": "VARCHAR(255)",
                  "nullable": false
                },
                {
                  "name": "_STG_FILE_NAME",
                  "type": "VARCHAR(500)",
                  "nullable": true,
                  "comment": "[cust360] Audit — source stage file name"
                },
                {
                  "name": "_STG_FILE_LOAD_TS",
                  "type": "TIMESTAMP_NTZ",
                  "nullable": true,
                  "comment": "[cust360] Audit — stage load timestamp"
                },
                {
                  "name": "_STG_FILE_MD5",
                  "type": "VARCHAR(64)",
                  "nullable": true,
                  "comment": "[cust360] Audit — SHA-256 hash of stage file"
                },
                {
                  "name": "_COPY_DATA_TS",
                  "type": "TIMESTAMP_NTZ",
                  "nullable": true,
                  "comment": "[cust360] Audit — COPY INTO execution timestamp"
                }
              ],
              "primary_key": {
                "keys": [
                  "ID"
                ]
              }
            }
          },
          "file_formats": {
            "json_file_format": {
              "name": "JSON_FILE_FORMAT",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "BRONZE",
              "type": "JSON",
              "compression": "NONE",
              "enable_octal": false,
              "allow_duplicate": false,
              "strip_outer_array": false,
              "strip_null_values": false,
              "ignore_utf8_errors": false,
              "comment": "[cust360] JSON parsing config for NorthBridge raw ingestion"
            }
          },
          "stages": {
            "raw_external_stg": {
              "name": "RAW_EXTERNAL_STG",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "BRONZE",
              "stage_type": "external",
              "url": "s3://the-s3-bucket/raw-data/json/",
              "storage_integration": "S3_STORAGE_INTEGRATION",
              "file_format": "JSON_FILE_FORMAT",
              "comment": "[cust360] External S3 stage for NorthBridge raw JSON ingestion"
            }
          },
          "snowpipes": {
            "raw_northbridge_pipe": {
              "name": "RAW_NORTHBRIDGE_PIPE",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "BRONZE",
              "table": "RAW_NORTHBRIDGE",
              "stage": "RAW_EXTERNAL_STG",
              "file_format": "JSON_FILE_FORMAT",
              "copy_template": "raw_northbridge_copy.tpl",
              "auto_ingest": true,
              "filter_suffix": ".json",
              "comment": "[cust360] Auto-ingest pipe — S3 to BRONZE.RAW_NORTHBRIDGE"
            }
          }
        },
        {
          "name": "SILVER",
          "comment": "[cust360] Cleansed and typed data layer",
          "dynamic_tables": {
            "clean_northbridge_dt": {
              "name": "CLEAN_NORTHBRIDGE_DT",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "SILVER",
              "warehouse": "LOAD_WH",
              "target_lag": "10 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "clean_northbridge.tpl",
              "source_schema": "BRONZE",
              "source_table": "RAW_NORTHBRIDGE",
              "comment": "[cust360] Cleansed and typed NorthBridge dataset — auto-refreshed from BRONZE",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            }
          }
        },
        {
          "name": "GOLD",
          "comment": "[cust360] Modelled data layer for analytics and dashboards",
          "dynamic_tables": {
            "dim_customer": {
              "name": "DIM_CUSTOMER",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "dim_customer.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Customer dimension (latest snapshot per customer)",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "dim_product": {
              "name": "DIM_PRODUCT",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "dim_product.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Product dimension derived from account data",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "dim_branch": {
              "name": "DIM_BRANCH",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "dim_branch.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Branch dimension from customer primary branch data",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "fact_transactions": {
              "name": "FACT_TRANSACTIONS",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "fact_transactions.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Transaction fact table",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "fact_loans": {
              "name": "FACT_LOANS",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "fact_loans.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Loan fact table",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "fact_account_balances": {
              "name": "FACT_ACCOUNT_BALANCES",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "warehouse": "LOAD_WH",
              "target_lag": "20 minute",
              "refresh_mode": "AUTO",
              "initialize": "ON_CREATE",
              "query_template_file": "fact_account_balances.tpl",
              "source_schema": "SILVER",
              "source_table": "CLEAN_NORTHBRIDGE_DT",
              "comment": "[cust360] Gold — Account balance fact table",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            }
          },
          "views": {
            "v_kpi_summary": {
              "name": "V_KPI_SUMMARY",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_kpi_summary.tpl",
              "comment": "[cust360] Gold — KPI summary view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "v_loan_portfolio": {
              "name": "V_LOAN_PORTFOLIO",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_loan_portfolio.tpl",
              "comment": "[cust360] Gold — Loan portfolio view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "v_monthly_txn_trends": {
              "name": "V_MONTHLY_TXN_TRENDS",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_monthly_txn_trends.tpl",
              "comment": "[cust360] Gold — Monthly transaction trends view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "v_regional_perf": {
              "name": "V_REGIONAL_PERF",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_regional_perf.tpl",
              "comment": "[cust360] Gold — Regional performance view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "v_risk_distribution": {
              "name": "V_RISK_DISTRIBUTION",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_risk_distribution.tpl",
              "comment": "[cust360] Gold — Risk distribution view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            },
            "v_segment_stats": {
              "name": "V_SEGMENT_STATS",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "GOLD",
              "query_template_file": "v_segment_stats.tpl",
              "comment": "[cust360] Gold — Customer segment stats view",
              "grants": [
                {
                  "role_name": "NORTHBRIDGE_ANALYST",
                  "privileges": [
                    "SELECT"
                  ]
                }
              ]
            }
          }
        },
        {
          "name": "STREAMLIT",
          "comment": "[cust360] Dashboard scripts for Streamlit in Snowflake",
          "stages": {
            "streamlit_stg": {
              "name": "STREAMLIT_STG",
              "database": "NORTHBRIDGE_DATABASE",
              "schema": "STREAMLIT",
              "stage_type": "internal",
              "directory_enabled": true,
              "comment": "[cust360] Internal stage hosting Streamlit app Python files"
            }
          }
        }
      ]
    }
  }
}
